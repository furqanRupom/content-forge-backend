enum UserRole {
    USER
    ADMIN
    MANAGER
}

model User {
    id           String   @id @default(uuid())
    name         String
    email        String   @unique
    passwordHash String
    role         UserRole @default(USER)
    isActive     Boolean  @default(true)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@map("users")
}
